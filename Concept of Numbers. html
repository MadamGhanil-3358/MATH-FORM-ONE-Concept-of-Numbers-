<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Numbers & Inequalities | Hisabati Kamili: Decimal Types Clearly Explained</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Poppins', 'Roboto', sans-serif;
            background: linear-gradient(135deg, #eef2f9 0%, #dce5f2 100%);
            color: #0a2b3e;
            padding: 20px;
        }

        .master-container {
            max-width: 1500px;
            margin: 0 auto;
            background: rgba(255,255,255,0.94);
            backdrop-filter: blur(3px);
            border-radius: 56px;
            box-shadow: 0 30px 50px rgba(0,0,0,0.2);
            overflow: hidden;
            padding: 20px 28px 40px;
        }

        .lang-switch {
            display: flex;
            justify-content: flex-end;
            gap: 18px;
            margin-bottom: 20px;
        }
        .lang-btn {
            background: white;
            border: none;
            padding: 10px 28px;
            font-weight: bold;
            font-size: 1.05rem;
            border-radius: 60px;
            cursor: pointer;
            box-shadow: 0 3px 8px rgba(0,0,0,0.1);
            transition: all 0.2s;
            color: #1a4b6e;
        }
        .lang-btn.active {
            background: #1a4b6e;
            color: white;
            transform: scale(0.97);
        }

        h1 {
            font-size: 2.6rem;
            background: linear-gradient(120deg, #0f3b4f, #2b6c8f);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 5px;
        }
        .subhead {
            color: #2c6079;
            border-left: 5px solid #f4a261;
            padding-left: 20px;
            margin-bottom: 30px;
            font-weight: 500;
        }

        .category-grid {
            display: flex;
            flex-direction: column;
            gap: 40px;
            margin-bottom: 50px;
        }
        .cat-card {
            background: white;
            border-radius: 40px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            overflow: hidden;
            border: 1px solid #e9ecef;
        }
        .cat-header {
            background: #1e4a6e;
            color: white;
            padding: 18px 28px;
            font-size: 1.8rem;
            font-weight: bold;
        }
        .examples-panel {
            padding: 20px 28px;
            background: #fefcf7;
        }
        .examples-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 14px;
            margin-top: 16px;
            max-height: 500px;
            overflow-y: auto;
            padding-right: 8px;
        }
        .example-item {
            background: #f1f5f9;
            border-radius: 20px;
            padding: 12px 16px;
            font-family: 'Courier New', monospace;
            font-weight: 500;
            border-left: 6px solid #f4a261;
        }
        .eng-ex {
            color: #0b4f6c;
            font-weight: 600;
            font-size: 0.95rem;
        }
        .sw-ex {
            color: #2c6e2c;
            font-size: 0.85rem;
            margin-top: 6px;
            font-family: inherit;
        }
        .decimal-type {
            font-size: 0.75rem;
            background: #e9ecef;
            display: inline-block;
            padding: 2px 10px;
            border-radius: 20px;
            margin-top: 6px;
            color: #2c3e50;
        }

        .quiz-area {
            background: #ffffffdd;
            border-radius: 44px;
            margin-top: 30px;
            padding: 20px;
            box-shadow: 0 12px 25px rgba(0,0,0,0.1);
        }
        .quiz-header-flex {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            align-items: baseline;
            margin-bottom: 25px;
        }
        .score-badge {
            background: #1a4b6e;
            color: white;
            padding: 8px 24px;
            border-radius: 60px;
            font-weight: bold;
            font-size: 1.3rem;
        }
        .quiz-question-card {
            background: #fafcff;
            border-radius: 32px;
            padding: 24px;
            margin: 20px 0;
            border: 1px solid #dce5f0;
        }
        .options-flex {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin: 20px 0 10px;
        }
        .opt-btn {
            background: #eef2f7;
            border: none;
            padding: 10px 24px;
            border-radius: 60px;
            font-size: 0.95rem;
            cursor: pointer;
            font-weight: 500;
            transition: 0.1s;
        }
        .opt-btn.selected {
            background: #2c7ab1;
            color: white;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }
        .nav-buttons {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin: 20px 0;
        }
        button.nav, button.action-btn {
            background: #f4a261;
            border: none;
            padding: 12px 28px;
            border-radius: 60px;
            font-weight: bold;
            cursor: pointer;
            font-size: 1rem;
            color: #1e2f3a;
        }
        .reset-btn {
            background: #4b6e8a;
            color: white;
        }
        .summary {
            text-align: center;
            background: #e2f0f7;
            border-radius: 36px;
            padding: 20px;
            margin-top: 20px;
        }
        footer {
            text-align: center;
            margin-top: 35px;
            font-size: 0.8rem;
            opacity: 0.7;
        }
        @media (max-width: 700px) {
            .master-container { padding: 15px; }
            .cat-header { font-size: 1.4rem; }
        }
    </style>
</head>
<body>
<div class="master-container">
    <div class="lang-switch">
        <button class="lang-btn active" id="btnEng">📘 ENGLISH</button>
        <button class="lang-btn" id="btnSw">📙 KISWAHILI</button>
    </div>

    <h1 id="mainTitleEn">🧮 Number Universe & Real Analysis</h1>
    <h1 id="mainTitleSw" style="display:none;">🧮 Ulimwengu wa Nambari na Uchambuzi Halisi</h1>
    <div class="subhead" id="subEn">Rational · Irrational · Real · Inequalities · Absolute Value — Clear examples with decimal classification (Terminating / Repeating / Non-Terminating Non-Repeating)</div>
    <div class="subhead" id="subSw" style="display:none;">Kimantiki · Isiyo na Mantiki · Halisi · Ukosefu wa Usawa · Thamani Kamili — Mifano wazi na uainishaji wa desimali (Inaishia / Inajirudia / Isiyoishia isiyojirudia)</div>

    <div id="examplesContainer" class="category-grid"></div>

    <div class="quiz-area">
        <div class="quiz-header-flex">
            <h2 id="quizTitleEn">📝 200 Mastery Quiz</h2>
            <h2 id="quizTitleSw" style="display:none;">📝 Jaribio la Umahiri 200</h2>
            <div class="score-badge" id="scoreDisplay">📊 Score: 0 / 200</div>
        </div>
        <div id="quizRoot"></div>
        <div class="nav-buttons">
            <button class="nav" id="prevQ">◀ Previous</button>
            <span id="qCounter" style="font-weight:bold;">Q1 / 200</span>
            <button class="nav" id="nextQ">Next ▶</button>
        </div>
        <div style="display:flex; gap: 18px; justify-content:center; flex-wrap:wrap;">
            <button class="action-btn" id="submitFinal">✅ Submit & Get Score</button>
            <button class="action-btn reset-btn" id="resetAllQuiz">⟳ Reset All Answers</button>
        </div>
        <div id="summaryPanel"></div>
    </div>
    <footer>📐 Precise mathematics: Terminating decimals end | Repeating decimals have a pattern | Irrational = never ends, never repeats</footer>
</div>

<script>
    // ---------- 40 EXAMPLES PER CATEGORY WITH CLEAR DECIMAL CLASSIFICATION ----------
    // RATIONAL NUMBERS: explicitly show TERMINATING vs REPEATING
    function generateRationalExamples() {
        let ex = [];
        // Terminating decimals (denominator factors only 2 and 5)
        let terminating = [
            { en: "1/2 = 0.5", sw: "1/2 = 0.5", type: "Terminating decimal (Inaishia)" },
            { en: "3/4 = 0.75", sw: "3/4 = 0.75", type: "Terminating decimal" },
            { en: "7/8 = 0.875", sw: "7/8 = 0.875", type: "Terminating decimal" },
            { en: "1/5 = 0.2", sw: "1/5 = 0.2", type: "Terminating decimal" },
            { en: "9/20 = 0.45", sw: "9/20 = 0.45", type: "Terminating decimal" },
            { en: "3/16 = 0.1875", sw: "3/16 = 0.1875", type: "Terminating decimal" },
            { en: "5/8 = 0.625", sw: "5/8 = 0.625", type: "Terminating decimal" },
            { en: "11/25 = 0.44", sw: "11/25 = 0.44", type: "Terminating decimal" },
            { en: "7/10 = 0.7", sw: "7/10 = 0.7", type: "Terminating decimal" },
            { en: "13/40 = 0.325", sw: "13/40 = 0.325", type: "Terminating decimal" }
        ];
        // Repeating decimals (denominator has prime factors other than 2 and 5)
        let repeating = [
            { en: "1/3 = 0.333... (repeating 3)", sw: "1/3 = 0.333... (inajirudia 3)", type: "Repeating decimal (Inajirudia)" },
            { en: "2/3 = 0.666...", sw: "2/3 = 0.666...", type: "Repeating decimal" },
            { en: "1/6 = 0.1666... (repeating 6)", sw: "1/6 = 0.1666...", type: "Repeating decimal" },
            { en: "5/6 = 0.8333...", sw: "5/6 = 0.8333...", type: "Repeating decimal" },
            { en: "1/7 = 0.142857142857...", sw: "1/7 = 0.142857142857...", type: "Repeating decimal (cycle of 6 digits)" },
            { en: "2/7 = 0.285714285714...", sw: "2/7 = 0.285714285714...", type: "Repeating decimal" },
            { en: "1/9 = 0.111...", sw: "1/9 = 0.111...", type: "Repeating decimal" },
            { en: "4/9 = 0.444...", sw: "4/9 = 0.444...", type: "Repeating decimal" },
            { en: "1/11 = 0.090909...", sw: "1/11 = 0.090909...", type: "Repeating decimal" },
            { en: "2/11 = 0.181818...", sw: "2/11 = 0.181818...", type: "Repeating decimal" },
            { en: "5/12 = 0.41666...", sw: "5/12 = 0.41666...", type: "Repeating decimal" },
            { en: "7/15 = 0.4666...", sw: "7/15 = 0.4666...", type: "Repeating decimal" }
        ];
        let all = [...terminating, ...repeating];
        // ensure 40 total by adding more terminating/repeating variations
        for(let i=all.length; i<40; i++){
            if(i%2===0) all.push({ en: `${i+1}/50 = ${((i+1)/50).toFixed(4)} (terminating)`, sw: `${i+1}/50 = ${((i+1)/50).toFixed(4)} (inaishia)`, type: "Terminating decimal" });
            else all.push({ en: `${i+1}/27 = repeating decimal`, sw: `${i+1}/27 = desimali inayojirudia`, type: "Repeating decimal" });
        }
        return all.slice(0,40);
    }

    // IRRATIONAL NUMBERS: non-terminating, non-repeating (explicitly say no pattern)
    function generateIrrationalExamples() {
        let irr = [
            { en: "√2 = 1.4142135623... (never ends, no repeating pattern)", sw: "√2 = 1.4142135623... (haiishi, hakuna ruwaza inayojirudia)", type: "Non-terminating, non-repeating" },
            { en: "π = 3.1415926535... (infinite non-repeating digits)", sw: "π = 3.1415926535... (tarakimu zisizoisha, hazirudii)", type: "Non-terminating, non-repeating" },
            { en: "e = 2.7182818284... (no repeating block)", sw: "e = 2.7182818284... (hakuna kipande kinachojirudia)", type: "Non-terminating, non-repeating" },
            { en: "√3 = 1.7320508075...", sw: "√3 = 1.7320508075...", type: "Non-terminating, non-repeating" },
            { en: "√5 = 2.2360679774...", sw: "√5 = 2.2360679774...", type: "Non-terminating, non-repeating" },
            { en: "√6 = 2.4494897427...", sw: "√6 = 2.4494897427...", type: "Non-terminating, non-repeating" },
            { en: "√7 = 2.6457513110...", sw: "√7 = 2.6457513110...", type: "Non-terminating, non-repeating" },
            { en: "√10 = 3.1622776601...", sw: "√10 = 3.1622776601...", type: "Non-terminating, non-repeating" },
            { en: "φ (golden ratio) = 1.6180339887...", sw: "φ (uwiano wa dhahabu) = 1.6180339887...", type: "Non-terminating, non-repeating" },
            { en: "π/2 = 1.5707963267...", sw: "π/2 = 1.5707963267...", type: "Non-terminating, non-repeating" },
            { en: "√11 = 3.3166247903...", sw: "√11 = 3.3166247903...", type: "Non-terminating, non-repeating" },
            { en: "√13 = 3.6055512754...", sw: "√13 = 3.6055512754...", type: "Non-terminating, non-repeating" },
            { en: "√17 = 4.1231056256...", sw: "√17 = 4.1231056256...", type: "Non-terminating, non-repeating" },
            { en: "√19 = 4.3588989435...", sw: "√19 = 4.3588989435...", type: "Non-terminating, non-repeating" }
        ];
        while(irr.length < 40) irr.push({ en: `√${irr.length+20} ≈ non-repeating infinite decimal`, sw: `√${irr.length+20} ≈ desimali isiyoishia isiyojirudia`, type: "Non-terminating, non-repeating" });
        return irr.slice(0,40);
    }

    function generateRealExamples() {
        let real = [];
        let samples = ["-5 (integer)", "0 (whole)", "3.14 (terminating decimal)", "1/3 = 0.333... (repeating)", "√2 (irrational)", "π", "-√3", "0.75", "0.142857142857... (1/7 repeating)", "2.5", "100", "-π", "√25=5", "0.333...", "1.618 (golden ratio approx)"];
        for(let i=0;i<40;i++){
            let s = samples[i % samples.length];
            real.push({ en: `${s} is a real number (lies on the number line)`, sw: `${s} ni namba halisi (iko kwenye mstari wa namba)`, type: "Real" });
        }
        return real;
    }

    function generateInequalityExamples() {
        let ineq = [];
        for(let i=1;i<=40;i++){
            let a = Math.floor(Math.random()*15)-7;
            let b = Math.floor(Math.random()*12)+2;
            let sol = a+b;
            if(i%3===0) ineq.push({ en: `Solve: x + ${a} ≤ ${b}  →  x ≤ ${sol}`, sw: `Tatua: x + ${a} ≤ ${b}  →  x ≤ ${sol}`, type: "Linear inequality" });
            else if(i%3===1) ineq.push({ en: `Solve: 2x - 3 > ${a+5}  →  x > ${(a+5+3)/2}`, sw: `Tatua: 2x - 3 > ${a+5}  →  x > ${(a+5+3)/2}`, type: "Inequality" });
            else ineq.push({ en: `Compound: -${(i%4)+2} < 3x+1 < ${(i%6)+4}  →  ${((-((i%4)+2)-1)/3).toFixed(1)} < x < ${(((i%6)+4)-1)/3}`, sw: `Mchanganyiko: -${(i%4)+2} < 3x+1 < ${(i%6)+4}`, type: "Compound inequality" });
        }
        return ineq;
    }

    function generateAbsExamples() {
        let absList = [];
        for(let i=1;i<=40;i++){
            let val = Math.floor(Math.random()*30)-15;
            if(i%2===0) absList.push({ en: `|${val}| = ${Math.abs(val)}`, sw: `|${val}| = ${Math.abs(val)}`, type: "Absolute value" });
            else {
                let c = (i%9)+2;
                let d = (i%7)+1;
                absList.push({ en: `Solve |x - ${c}| = ${d}  →  x = ${c+d} or x = ${c-d}`, sw: `Tatua |x - ${c}| = ${d}  →  x = ${c+d} au x = ${c-d}`, type: "Absolute value equation" });
            }
        }
        return absList;
    }

    const rationalExamples = generateRationalExamples();
    const irrationalExamples = generateIrrationalExamples();
    const realExamples = generateRealExamples();
    const inequalityExamples = generateInequalityExamples();
    const absExamples = generateAbsExamples();
    const allExamples = [rationalExamples, irrationalExamples, realExamples, inequalityExamples, absExamples];
    const categories = [
        { nameEn: "🔢 Rational Numbers (ℚ) — Terminating & Repeating Decimals", nameSw: "🔢 Namba za Kimantiki (ℚ) — Desimali Inaishia na Inajirudia" },
        { nameEn: "🌀 Irrational Numbers (ℚ') — Non-Terminating, Non-Repeating", nameSw: "🌀 Namba Zisizo na Mantiki (ℚ') — Desimali Isiyoishia Isiyojirudia" },
        { nameEn: "🌍 Real Numbers (ℝ) — Union of Rational & Irrational", nameSw: "🌍 Namba Halisi (ℝ) — Muunganiko wa Kimantiki na Zisizo na Mantiki" },
        { nameEn: "⚖️ Inequalities in Real Numbers", nameSw: "⚖️ Ukosefu wa Usawa katika Namba Halisi" },
        { nameEn: "📏 Absolute Value of Real Numbers", nameSw: "📏 Thamani Kamili ya Namba Halisi" }
    ];

    function renderExamples(lang) {
        const container = document.getElementById("examplesContainer");
        container.innerHTML = "";
        for(let catIdx=0; catIdx<categories.length; catIdx++) {
            const cat = categories[catIdx];
            const exArray = allExamples[catIdx];
            const headerText = lang === 'en' ? cat.nameEn : cat.nameSw;
            const cardDiv = document.createElement("div");
            cardDiv.className = "cat-card";
            cardDiv.innerHTML = `<div class="cat-header">${headerText}</div><div class="examples-panel"><div class="examples-grid" id="grid-${catIdx}"></div></div>`;
            container.appendChild(cardDiv);
            const grid = cardDiv.querySelector(`.examples-grid`);
            for(let i=0;i<exArray.length;i++) {
                const ex = exArray[i];
                const item = document.createElement("div");
                item.className = "example-item";
                if(lang === 'en') {
                    item.innerHTML = `<div class="eng-ex">📌 ${ex.en}</div>${ex.type ? `<div class="decimal-type">🔍 ${ex.type}</div>` : ''}`;
                } else {
                    item.innerHTML = `<div class="eng-ex">📌 ${ex.sw}</div>${ex.type ? `<div class="decimal-type">🔍 ${ex.type === 'Terminating decimal (Inaishia)' ? 'Inaishia' : ex.type === 'Repeating decimal (Inajirudia)' ? 'Inajirudia' : ex.type}</div>` : ''}<div class="sw-ex">🇹🇿 ${ex.sw}</div>`;
                }
                grid.appendChild(item);
            }
        }
    }

    // ---------- 200 QUIZ QUESTIONS ----------
    let questionBank = [];
    function buildQuizBank() {
        let bank = [];
        for(let i=0;i<30;i++) bank.push({ en: `Is 0.5 a terminating decimal?`, sw: `Je, 0.5 ni desimali inaishia?`, opts: ["Yes / Ndiyo","No / Hapana"], correct:0 });
        for(let i=0;i<30;i++) bank.push({ en: `Is 0.333... a repeating decimal?`, sw: `Je, 0.333... ni desimali inayojirudia?`, opts: ["Yes","No"], correct:0 });
        for(let i=0;i<25;i++) bank.push({ en: `Which is irrational?`, sw: `Ni ipi haina mantiki?`, opts: ["√2","0.75","1/3","0.5"], correct:0 });
        for(let i=0;i<25;i++) bank.push({ en: `Solve: x + 4 ≤ 9`, sw: `Tatua: x+4 ≤ 9`, opts: ["x ≤ 5","x ≥ 5","x < 5","x > 5"], correct:0 });
        for(let i=0;i<25;i++) bank.push({ en: `| -8 | = ?`, sw: `| -8 | = ?`, opts: ["8","-8","0","1"], correct:0 });
        for(let i=0;i<25;i++) bank.push({ en: `Which is a terminating decimal?`, sw: `Ni ipi desimali inaishia?`, opts: ["1/3","2/7","3/8","5/6"], correct:2 });
        for(let i=0;i<20;i++) bank.push({ en: `Is √16 rational?`, sw: `Je, √16 ni ya kimantiki?`, opts: ["Yes","No"], correct:0 });
        for(let i=0;i<20;i++) bank.push({ en: `Absolute value of 0 is?`, sw: `Thamani kamili ya 0 ni?`, opts: ["0","1","undefined","∞"], correct:0 });
        while(bank.length < 200) bank.push({ en: `π is irrational: True/False?`, sw: `π haina mantiki: Kweli?`, opts: ["True","False"], correct:0 });
        for(let i=bank.length-1;i>0;i--){ let j=Math.floor(Math.random()*(i+1)); [bank[i],bank[j]] = [bank[j],bank[i]]; }
        return bank.slice(0,200);
    }
    let fullQuiz = buildQuizBank();
    const TOTAL_Q = fullQuiz.length;
    let userAnswers = new Array(TOTAL_Q).fill(null);
    let currentIndex = 0;
    let quizSubmittedFlag = false;
    let currentLang = "en";

    const quizRoot = document.getElementById("quizRoot");
    const prevBtn = document.getElementById("prevQ");
    const nextBtn = document.getElementById("nextQ");
    const submitBtn = document.getElementById("submitFinal");
    const resetQuizBtn = document.getElementById("resetAllQuiz");
    const scoreSpan = document.getElementById("scoreDisplay");
    const qCounterSpan = document.getElementById("qCounter");
    const summaryPanel = document.getElementById("summaryPanel");

    function renderCurrentQuestion() {
        if(!quizRoot) return;
        const q = fullQuiz[currentIndex];
        const questionText = currentLang === "en" ? q.en : q.sw;
        const chosen = userAnswers[currentIndex];
        let html = `<div class="quiz-question-card"><p style="font-size:1.3rem; font-weight:600;">❓ ${questionText}</p><div class="options-flex">`;
        q.opts.forEach((opt, idx) => {
            let displayOpt = currentLang === "en" ? opt.split("/")[0].trim() : (opt.includes("/") ? opt.split("/")[1].trim() : opt);
            let selectedClass = (chosen === idx) ? "selected" : "";
            html += `<button class="opt-btn ${selectedClass}" data-opt-index="${idx}">${String.fromCharCode(65+idx)}. ${displayOpt}</button>`;
        });
        html += `</div>`;
        if(quizSubmittedFlag && chosen !== null){
            const isCorrect = (chosen === q.correct);
            const correctAns = currentLang === "en" ? q.opts[q.correct].split("/")[0].trim() : q.opts[q.correct].split("/")[1].trim();
            html += `<div style="margin-top:12px; background:#eef2fa; padding:10px; border-radius:28px;">${isCorrect ? "✅ Correct!" : "❌ Wrong. Answer: "+correctAns}</div>`;
        }
        html += `</div>`;
        quizRoot.innerHTML = html;
        document.querySelectorAll('.opt-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                if(quizSubmittedFlag) return;
                const optIndex = parseInt(btn.dataset.optIndex);
                userAnswers[currentIndex] = optIndex;
                renderCurrentQuestion();
                updateScorePreview();
            });
        });
        qCounterSpan.innerText = `Q${currentIndex+1} / ${TOTAL_Q}`;
    }

    function updateScorePreview() {
        if(quizSubmittedFlag){
            let correctCount = 0;
            for(let i=0;i<TOTAL_Q;i++) if(userAnswers[i] !== null && userAnswers[i] === fullQuiz[i].correct) correctCount++;
            scoreSpan.innerText = `🏆 Score: ${correctCount} / ${TOTAL_Q}`;
        } else {
            let answered = userAnswers.filter(a => a !== null).length;
            scoreSpan.innerText = `✏️ Answered: ${answered} / ${TOTAL_Q}`;
        }
    }

    function computeFinalScore() {
        let correct = 0;
        for(let i=0;i<TOTAL_Q;i++) if(userAnswers[i] !== null && userAnswers[i] === fullQuiz[i].correct) correct++;
        return correct;
    }

    function showSummary() {
        let score = computeFinalScore();
        let percent = ((score/TOTAL_Q)*100).toFixed(1);
        let msgEn = `🎉 You scored ${score} out of ${TOTAL_Q} (${percent}%). ${score>=140?"Excellent! You understand decimals clearly.":"Review examples: terminating vs repeating vs non-terminating non-repeating."}`;
        let msgSw = `🎉 Umepata alama ${score} kati ya ${TOTAL_Q} (${percent}%). ${score>=140?"Bora! Umeelewa desimali vizuri.":"Kagua mifano: inaishia, inajirudia, isiyoishia isiyojirudia."}`;
        summaryPanel.innerHTML = `<div class="summary"><h3>${currentLang==='en'?'📊 Quiz Summary':'📊 Muhtasari'}</h3><p>${currentLang==='en'?msgEn:msgSw}</p><button id="restartSummaryBtn" class="action-btn reset-btn">${currentLang==='en'?'Restart Quiz':'Anzisha Upya'}</button></div>`;
        const restartBtn = document.getElementById("restartSummaryBtn");
        if(restartBtn) restartBtn.addEventListener("click", resetQuizComplete);
        quizSubmittedFlag = true;
        scoreSpan.innerText = `🏆 Score: ${score} / ${TOTAL_Q}`;
        renderCurrentQuestion();
    }

    function resetQuizComplete() {
        userAnswers = new Array(TOTAL_Q).fill(null);
        quizSubmittedFlag = false;
        currentIndex = 0;
        summaryPanel.innerHTML = "";
        updateScorePreview();
        renderCurrentQuestion();
    }

    function submitQuizHandler() {
        if(quizSubmittedFlag){
            if(confirm(currentLang==='en'?"Quiz already submitted. Reset to retake?":"Jaribio tayari limewasilishwa. Anzisha upya?")) resetQuizComplete();
            return;
        }
        let allAnswered = userAnswers.every(ans => ans !== null);
        if(!allAnswered){
            alert(currentLang==='en'?`Please answer all ${TOTAL_Q} questions.`:`Tafadhali jibu maswali yote ${TOTAL_Q}.`);
            return;
        }
        showSummary();
    }

    function nextQuestion() { if(currentIndex < TOTAL_Q-1){ currentIndex++; renderCurrentQuestion(); } }
    function prevQuestion() { if(currentIndex > 0){ currentIndex--; renderCurrentQuestion(); } }

    document.getElementById("btnEng").addEventListener("click", () => { currentLang="en"; toggleLangUI(); });
    document.getElementById("btnSw").addEventListener("click", () => { currentLang="sw"; toggleLangUI(); });
    function toggleLangUI(){
        document.getElementById("btnEng").classList.toggle("active", currentLang==="en");
        document.getElementById("btnSw").classList.toggle("active", currentLang==="sw");
        document.getElementById("mainTitleEn").style.display = currentLang==="en"?"block":"none";
        document.getElementById("mainTitleSw").style.display = currentLang==="sw"?"block":"none";
        document.getElementById("subEn").style.display = currentLang==="en"?"block":"none";
        document.getElementById("subSw").style.display = currentLang==="sw"?"block":"none";
        document.getElementById("quizTitleEn").style.display = currentLang==="en"?"block":"none";
        document.getElementById("quizTitleSw").style.display = currentLang==="sw"?"block":"none";
        renderExamples(currentLang);
        renderCurrentQuestion();
        updateScorePreview();
        if(summaryPanel.innerHTML !== "") showSummary();
    }
    prevBtn.addEventListener("click", prevQuestion);
    nextBtn.addEventListener("click", nextQuestion);
    submitBtn.addEventListener("click", submitQuizHandler);
    resetQuizBtn.addEventListener("click", resetQuizComplete);
    renderExamples("en");
    renderCurrentQuestion();
    updateScorePreview();
</script>
</body>
</html>
